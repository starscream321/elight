# Yandex IoT API Token
YANDEX_TOKEN="your_yandex_token_here"

# API Key for authentication
API_KEY="super_api"

# Art-Net Configuration
ARTNET_IP="192.168.6.11"
TOTAL_DIODES=5100
EFFECTS_FPS=60

# Database
TYPEORM_SYNCHRONIZE=false

# Audio Device: "auto", "pulse:<source>", "alsa:<device>", or raw ALSA device name
AUDIO_DEVICE="alsa:plughw:0,2"
AUDIO_CHANNELS=2
AUDIO_AUTO_MIN_RMS=0.002
AUDIO_NOISE_FLOOR_RMS=0.006
AUDIO_DEBUG=true
AUDIO_DEBUG_INTERVAL_MS=1000
AUDIO_PULSE_LATENCY_MS=20
AUDIO_ALSA_PERIOD_MS=10
AUDIO_ALSA_BUFFER_MS=30
AUDIO_NORMALIZE_TARGET_RMS=0.06
AUDIO_NORMALIZE_TARGET_PEAK=0.35
AUDIO_NORMALIZE_MIN_GAIN=0.05
AUDIO_NORMALIZE_MAX_GAIN=7
